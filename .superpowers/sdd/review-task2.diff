+.glass-panel-interactive {

+  position: relative;

+  overflow: hidden;

+}

+

+.glass-panel-interactive::after {

+  content: '';

+  position: absolute;

+  top: 0;

+  left: 0;

+  width: 50%;

+  height: 100%;

+  background: linear-gradient(

