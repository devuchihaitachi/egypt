+/* Navbar Styling */

+.navbar {

+  position: fixed;

+  top: 0;

+  left: 0;

+  width: 100%;

+  height: 70px;

+  display: flex;

+  justify-content: space-between;

+  align-items: center;

+  padding: 0 2rem;

