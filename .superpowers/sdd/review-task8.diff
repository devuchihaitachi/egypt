+    global.IntersectionObserver = class {

+      constructor(cb) { this.cb = cb; }

+      observe(el) { this.cb([{ isIntersecting: true, target: el }]); }

+      unobserve() {}

+      disconnect() {}

+    };

+  });

+

+  it('renders Eternal Egypt heading', () => {

+    render(<App />);

